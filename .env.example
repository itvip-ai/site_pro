# ===== Application =====
NODE_ENV=development
PORT=3000

# ===== Database =====
# Path to the SQLite file (relative to project root). To move to Postgres/MySQL
# later, swap the query layer in src/config/db.js — see README.
DATABASE_URL=./data/qgroup.db

# ===== Session =====
# CHANGE THIS to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# ===== Default admin (used by `npm run seed`) =====
ADMIN_LOGIN=admin
ADMIN_PASSWORD=qgroup2024

# ===== Image processing / upload =====
MAX_FILE_SIZE=5242880
IMAGE_MAX_WIDTH=1000
IMAGE_PREVIEW_WIDTH=400
IMAGE_QUALITY=80
