    </div>
  </main>

  <footer class="site-footer">
    <div class="container site-footer__inner">
      <span>© <%= new Date().getFullYear() %> QGROUP — <%= t('footer.rights') %></span>
      <span class="muted"><%= t('footer.usd') %></span>
    </div>
  </footer>

  <script src="/js/app.js" defer></script>
  <% if (typeof role !== 'undefined' && (role === 'admin' || role === 'sales' || role === 'partner')) { %>
    <script src="/js/cart.js" defer></script>
  <% } %>
</body>
</html>
